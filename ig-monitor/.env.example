# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ig_monitor?schema=public"

# Handles list (comma-separated)
HANDLES="alarabiya.farsi,manotoofficial,radiofarda,iranintltv,euronews_persian,voafarsi,radiozamaneh,bbcpersian,dw_persian"

# Cron schedules
SCRAPE_INTERVAL_CRON="*/10 * * * *"
RECOMPUTE_INTERVAL_CRON="0 */2 * * *"

# Trending thresholds
MIN_TREND_INTERACTIONS="50"
TREND_RATIO_THRESHOLD="2.0"

# Proxy (optional)
HTTP_PROXY=""
HTTPS_PROXY=""

# Alerts (optional)
SLACK_WEBHOOK_URL=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""